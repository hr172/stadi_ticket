# Stadi Soka-Ticket — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── Flask ────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
DATABASE_URL=sqlite:///stadi_soka.db

# ── M-Pesa Daraja ────────────────────────────────────────
# Set MPESA_ENV=production when going live; sandbox uses simulated callbacks
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key_from_developer_safaricom_com
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
# Public HTTPS URL Safaricom will POST callbacks to
MPESA_CALLBACK_URL=https://your-domain.co.ke/mpesa/callback

# ── Internal ─────────────────────────────────────────────
# Secret header value for the /internal/cleanup_holds endpoint
CLEANUP_SECRET=change-this-cleanup-secret
